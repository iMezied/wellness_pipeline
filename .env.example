# ════════════════════════════════════════════════════════════
# .env — انسخ هذا الملف إلى .env وعبّئ القيم
# لا ترفع هذا الملف على Git أبداً (.gitignore مضاف تلقائياً)
# ════════════════════════════════════════════════════════════

# ── Brand ─────────────────────────────────────────────────
BRAND_NAME=Mujarbat
DISCLAIMER_AR=المحتوى مبني على دراسات موثقة. استشر طبيبك.

# ── Database ──────────────────────────────────────────────
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=wellness_pipeline
DB_USER=wellness_user
DB_PASS=your_secure_password

# ── AI APIs ───────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
KLING_API_KEY=...
ASSEMBLY_API_KEY=...

# ── Social Publishing ─────────────────────────────────────
# Optional flags (best practice): true/false
# If omitted, each platform is auto-enabled only when its required credentials exist.
# TIKTOK_ENABLED=true
# INSTAGRAM_ENABLED=true
# YOUTUBE_ENABLED=true
# PINTEREST_ENABLED=true
# SNAPCHAT_ENABLED=true

TIKTOK_ACCESS_TOKEN=...
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...
YOUTUBE_CLIENT_SECRET={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}
PINTEREST_ACCESS_TOKEN=...
PINTEREST_BOARD_ID=...
SNAPCHAT_ACCESS_TOKEN=...

# ── CDN (Cloudflare R2) ───────────────────────────────────
R2_ACCOUNT_ID=...
R2_ACCESS_KEY=...
R2_SECRET_KEY=...
R2_BUCKET=wellness-videos
R2_PUBLIC_DOMAIN=videos.yourdomain.com
